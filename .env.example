# --- БАЗА ДАННЫХ (PostgreSQL, напр. Supabase / Neon) ---
# Pooled connection (через pgbouncer) — для приложения:
DATABASE_URL="postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
# Прямое подключение — для миграций и seed:
DIRECT_URL="postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres"

# --- СЕССИИ ---
# Любая длинная случайная строка (32+ символов). Сгенерировать: openssl rand -base64 32
SESSION_SECRET="change-me-before-production"
ADMIN_EMAILS="owner@example.com"
ANALYTICS_SALT="change-me-before-production-analytics-salt"

# --- ПУБЛИЧНЫЙ АДРЕС САЙТА ---
# Можно не задавать на Vercel: он сам даст VERCEL_URL.
# Если подключим свой домен, сюда ставим его, например:
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# --- ВХОД ЧЕРЕЗ СОЦСЕТИ (OAuth) ---
# Кнопка появляется автоматически, как только заданы CLIENT_ID и SECRET провайдера.
# Базовый адрес для redirect URI. Если не задан — берётся NEXT_PUBLIC_SITE_URL, затем origin запроса.
# ВАЖНО: должен ТОЧНО совпадать с тем, что прописан в консоли провайдера.
OAUTH_REDIRECT_BASE="https://your-domain.vercel.app"
# Redirect URI для каждого провайдера: {OAUTH_REDIRECT_BASE}/api/auth/oauth/{google|vk|yandex}/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
VK_CLIENT_ID=""
VK_CLIENT_SECRET=""
YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""

# --- Платежи (можно оставить пустыми — работает демо-режим) ---
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Синхронизация просмотров (опционально, иначе мок-данные) ---
YOUTUBE_DATA_API_KEY=""
VK_SERVICE_TOKEN=""

# --- Будущие OAuth-интеграции (необязательно) ---
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
