generator client {
  provider      = "prisma-client-js"
  // native = build host; rhel targets = Netlify Functions (AWS Lambda) runtime
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  name            String
  handle          String            @unique
  avatar          String?
  role            Role              @default(WORKER)
  balanceCents    Int               @default(0)
  holdBalanceCents Int              @default(0)
  rank            Rank              @default(BRONZE)
  trustScore      Int               @default(100)
  streakDays      Int               @default(0)
  lifetimeViews   Int               @default(0)
  referredBy      String?
  referralCode    String            @unique
  kycStatus       KYCStatus         @default(NONE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  ownedCampaigns  Campaign[]        @relation("CampaignOwner")
  submissions     Submission[]
  transactions    Transaction[]
  socialAccounts  SocialAccount[]
  oauthAccounts   OAuthAccount[]
  notifications   Notification[]
  achievements    UserAchievement[]
  disputes        DisputeCase[]
  auditLogs        AuditLog[]
  savedCampaigns  SavedCampaign[]
  likedCampaigns  LikedCampaign[]
  analyticsEvents AnalyticsEvent[]
  clientChats     ChatThread[]      @relation("ChatClient")
  workerChats     ChatThread[]      @relation("ChatWorker")
  sentChatMessages ChatMessage[]    @relation("ChatSender")
}

model SocialAccount {
  id           String    @id @default(cuid())
  userId       String
  platform     Platform
  externalId   String
  handle       String
  accessToken  String?
  refreshToken String?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, externalId])
}

// Social login (Google / VK / Yandex). Stores ONLY the identity link —
// no access/refresh tokens are kept (we never act on the user's behalf).
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Campaign {
  id                   String          @id @default(cuid())
  ownerId              String
  title                String
  description          String
  sourceUrl            String
  sourcePlatform       Platform
  allowedPlatformsJson String
  rulesJson            String
  cpmRateCents         Int
  viewThreshold        Int
  totalBudgetCents     Int
  remainingBudgetCents Int
  status               CampaignStatus @default(ACTIVE)
  visibility           Visibility      @default(PUBLIC)
  trackingPrefix       String          @unique
  deadline             DateTime
  language             String          @default("ru")
  niche                String?
  metricsJson          String          @default("{}")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  owner                User            @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  submissions          Submission[]
  savedBy              SavedCampaign[]
  likedBy              LikedCampaign[]
  chatThreads          ChatThread[]
}

model SavedCampaign {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
}

model LikedCampaign {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
}

model Submission {
  id               String           @id @default(cuid())
  campaignId       String
  workerId         String
  postUrl          String
  platform         Platform
  platformPostId   String
  trackingCode     String           @unique
  currentViews     Int              @default(0)
  currentLikes     Int              @default(0)
  currentComments  Int              @default(0)
  peakViews        Int              @default(0)
  status           SubmissionStatus @default(POSTED)
  fraudScore       Int              @default(0)
  viewVelocityJson String           @default("[]")
  lastSyncedAt     DateTime         @default(now())
  verifiedAt       DateTime?
  paidAt           DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  campaign         Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  worker           User             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  disputes         DisputeCase[]
  chatThreads       ChatThread[]
  videoChecks       VideoCheck[]
}

model VideoCheck {
  id           String     @id @default(cuid())
  submissionId String
  checkType    String     @default("WATERMARK")
  status       String     @default("PENDING")
  score        Int        @default(0)
  resultJson   String     @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([submissionId])
}

model ChatThread {
  id           String        @id @default(cuid())
  campaignId   String
  submissionId String?
  clientId     String
  workerId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submission   Submission?   @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  client       User          @relation("ChatClient", fields: [clientId], references: [id], onDelete: Cascade)
  worker       User          @relation("ChatWorker", fields: [workerId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@unique([campaignId, workerId])
  @@index([clientId, updatedAt])
  @@index([workerId, updatedAt])
}

model ChatMessage {
  id           String      @id @default(cuid())
  threadId     String
  senderId     String
  body         String
  type         String      @default("TEXT")
  metadataJson String      @default("{}")
  createdAt    DateTime    @default(now())

  thread       ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender       User        @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderId, createdAt])
}

model Transaction {
  id           String            @id @default(cuid())
  userId       String
  submissionId String?
  amountCents  Int
  feeCents     Int               @default(0)
  netCents     Int
  type         TransactionType
  status       TransactionStatus @default(COMPLETED)
  provider     String?
  providerData String            @default("{}")
  createdAt    DateTime          @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission   Submission?       @relation(fields: [submissionId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  channel   String
  priority  String
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String            @id @default(cuid())
  code        String            @unique
  title       String
  description String
  icon        String
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model LeaderboardSnapshot {
  id          String   @id @default(cuid())
  season      String
  type        String
  handle      String
  rank        Int
  views       Int
  payoutCents Int
  createdAt   DateTime @default(now())
}

model DisputeCase {
  id           String     @id @default(cuid())
  userId       String
  submissionId String
  reason       String
  status       String     @default("OPEN")
  createdAt    DateTime   @default(now())
  resolvedAt   DateTime?

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  userId        String?
  type          String
  path          String?
  provider      String?
  ipHash        String?
  userAgentHash String?
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([path, createdAt])
  @@index([provider, createdAt])
  @@index([ipHash, createdAt])
}

enum Role {
  CLIENT
  WORKER
  BOTH
  ADMIN
}

enum Rank {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  LEGENDARY
}

enum KYCStatus {
  NONE
  PENDING
  VERIFIED
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  VK
  TWITCH
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  LOW_BUDGET
  PAUSED
  COMPLETED
}

enum Visibility {
  PUBLIC
  FEATURED
  PRIVATE_INVITE
}

enum SubmissionStatus {
  ACCEPTED
  POSTED
  VERIFIED
  THRESHOLD_MET
  SETTLING
  PAID
  REJECTED
}

enum TransactionType {
  DEPOSIT
  EARNING
  WITHDRAWAL
  REFERRAL_BONUS
  STREAK_BONUS
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}
